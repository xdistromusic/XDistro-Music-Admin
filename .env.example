# Admin now runs in REST mode only.
# These variables are kept for backward compatibility but are ignored.
VITE_ADMIN_AUTH_MODE=rest
VITE_ADMIN_DATA_MODE=rest

# Backend base URL used when VITE_ADMIN_AUTH_MODE=rest.
# Example: http://localhost:3000/api/admin
VITE_ADMIN_API_BASE_URL=/api/admin

# Optional royalty import endpoint when uploads are handled by a dedicated service.
# Example: https://<project-ref>.supabase.co/functions/v1/royalty-imports
VITE_ADMIN_ROYALTY_IMPORT_URL=

